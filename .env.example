# OpenAI API key for Whisper transcription
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-REPLACE_ME

# Optional: force language (ISO-639-1) — improves accuracy if you always dictate in one language.
# Leave empty or unset for autodetect (works well for mixed ru/en).
# Examples: ru, en, de
KWISPR_LANGUAGE=

# Auto-paste after transcription via ydotool (requires ydotoold systemd service).
# The script copies the text to clipboard and then simulates Ctrl+V in the
# focused window. Set to 0 to disable and only copy to clipboard.
KWISPR_AUTOPASTE=1

# Play short sound cues on recording start/stop/ready. Set to 0 to disable.
# Defaults: generated tones in sounds/ — 3 high pips at start, 3 low pups
# at stop, ascending ding-dong when transcript is ready.
# Override paths manually:
# KWISPR_SOUND_START=/path/to/start.wav
# KWISPR_SOUND_STOP=/path/to/stop.wav
# KWISPR_SOUND_READY=/path/to/ready.wav
KWISPR_SOUNDS=1
