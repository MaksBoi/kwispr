# Transcription backend.
# - openai-transcriptions: OpenAI-compatible /v1/audio/transcriptions endpoint
# - openrouter-chat: OpenRouter /chat/completions with base64 input_audio
KWISPR_BACKEND=openai-transcriptions
KWISPR_API_URL=https://api.openai.com/v1/audio/transcriptions
KWISPR_MODEL=whisper-1

# API key. OPENAI_API_KEY is still supported for backward compatibility,
# but KWISPR_API_KEY works with OpenAI, OpenRouter, and compatible backends.
# Get an OpenAI key at https://platform.openai.com/api-keys
KWISPR_API_KEY=sk-REPLACE_ME
# OPENAI_API_KEY=sk-REPLACE_ME

# Local/offline STT config. Start a local OpenAI-compatible server first.
# No cloud API key is required for this mode; leave KWISPR_API_KEY empty.
# KWISPR_BACKEND=openai-transcriptions
# KWISPR_API_URL=http://127.0.0.1:9000/v1/audio/transcriptions
# KWISPR_MODEL=gigaam-v3-e2e-ctc
# KWISPR_API_KEY=
# KWISPR_LANGUAGE=ru
# KWISPR_MODEL_DIR=~/.local/share/kwispr/models
# Optional local-runtime VAD preprocessing. Disabled by default to keep
# behavior unchanged. Enable to trim leading/trailing silence and skip
# no-voice/short-noise clips before local STT inference.
# KWISPR_VAD_ENABLED=1
# KWISPR_VAD_THRESHOLD=0.01
# KWISPR_VAD_FRAME_MS=30
# KWISPR_VAD_MIN_SPEECH_MS=150
# KWISPR_VAD_PADDING_MS=120

# Optional OpenRouter config. OpenRouter audio inputs use chat/completions.
# KWISPR_BACKEND=openrouter-chat
# KWISPR_API_URL=https://openrouter.ai/api/v1/chat/completions
# KWISPR_MODEL=google/gemini-2.5-flash
# KWISPR_API_KEY=sk-or-...
# KWISPR_HTTP_REFERER=https://github.com/MaksBoi/kwispr
# KWISPR_APP_TITLE=kwispr
# KWISPR_AUDIO_FORMAT=wav
# KWISPR_PULSE_SOURCE=default
# KWISPR_TRANSCRIPTION_PROMPT='Transcribe this audio exactly as spoken. The speech may be Russian, English, or mixed. Do not translate. Return only the transcript.'

# Optional: force language (ISO-639-1) — improves accuracy if you always dictate in one language.
# Leave empty or unset for autodetect (works well for mixed ru/en).
# Examples: ru, en, de
KWISPR_LANGUAGE=

# Auto-paste after transcription via ydotool (requires ydotoold systemd service).
# The script copies the text to clipboard and then simulates Ctrl+V in the
# focused window. Set to 0 to disable and only copy to clipboard.
KWISPR_AUTOPASTE=1

# Play short sound cues on recording start/stop/ready. Set to 0 to disable.
# Defaults: generated tones in sounds/ — 3 high pips at start, 3 low pups
# at stop, ascending ding-dong when transcript is ready.
# Override paths manually:
# KWISPR_SOUND_START=/path/to/start.wav
# KWISPR_SOUND_STOP=/path/to/stop.wav
# KWISPR_SOUND_READY=/path/to/ready.wav
KWISPR_SOUNDS=1
